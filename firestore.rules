rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- BASIC HELPERS ---
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userRole() {
      return (signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role 
        : null;
    }

    function isRole(role) {
      return signedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.lower() == role.lower();
    }

    function isStakeholder() {
      return isRole('Stakeholder');
    }

    function isEntrepreneur() {
      return isRole('Entrepreneur');
    }

    function isInvestor() {
      return isRole('Investor');
    }

    function isAdmin() {
      return isRole('Admin');
    }

    function isChatParticipant(chatId) {
      return signedIn() && (
        request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants ||
        get(/databases/$(database)/documents/chats/$(chatId)).data.investorId == request.auth.uid ||
        get(/databases/$(database)/documents/chats/$(chatId)).data.entrepreneurId == request.auth.uid
      );
    }

    function canAccessChat(data) {
      return signedIn() && (
        (data.participants is list && request.auth.uid in data.participants) ||
        data.investorId == request.auth.uid ||
        data.entrepreneurId == request.auth.uid
      );
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if isOwner(userId) || isAdmin();
    }

    match /pitches/{pitchId} {
      allow read: if signedIn(); 
      allow create: if isEntrepreneur();
      allow update: if signedIn() && (
        isOwner(resource.data.userId) || isOwner(resource.data.entrepreneurId)
        || isInvestor() // Investors can express interest (updates raisedAmount/interested)
        || isStakeholder() // Stakeholders update vetting status
        || isAdmin()
      );
    }

    match /milestones/{milestoneId} {
      // Global read for stakeholders to find vetting tasks
      allow read: if signedIn();
      allow create: if isEntrepreneur();
      allow update: if signedIn() && (
        (isEntrepreneur() && resource.data.entrepreneurId == request.auth.uid) ||
        isStakeholder() || isAdmin()
      );
    }

    match /meetings/{meetingId} {
      // Diagnostic proved list/get works if auth. 
      // Restoring privacy: only participants can see the meeting.
      allow read: if signedIn() && (
        resource.data.stakeholderId == request.auth.uid || 
        resource.data.entrepreneurId == request.auth.uid
      );
      
      // Allow creation if the user is authenticated and claiming their own ID
      allow create: if signedIn() && request.resource.data.stakeholderId == request.auth.uid;
      
      allow update, delete: if signedIn() && request.auth.uid == resource.data.stakeholderId;
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || resource.data.recipientId == request.auth.uid || isAdmin());
      allow create: if signedIn();
      allow update: if signedIn() && (resource.data.userId == request.auth.uid || resource.data.recipientId == request.auth.uid || isAdmin());
    }

    match /system_settings/{settingId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /pitchViews/{viewId} {
      allow create: if signedIn() && request.resource.data.investorId == request.auth.uid;
      allow read: if signedIn() && (
        resource.data.investorId == request.auth.uid ||
        resource.data.entrepreneurId == request.auth.uid
      );
    }

    match /chats/{chatId} {
      allow read: if canAccessChat(resource.data);
      allow create: if canAccessChat(request.resource.data);
      allow update: if canAccessChat(resource.data) && canAccessChat(request.resource.data);
      
      match /messages/{messageId} {
        allow read, create: if isChatParticipant(chatId);
      }
    }

    match /transactions/{transactionId} {
      allow read: if signedIn() && (
        resource.data.investorId == request.auth.uid ||
        resource.data.entrepreneurId == request.auth.uid ||
        resource.data.userId == request.auth.uid
      );
      allow create: if isInvestor();
    }

    match /investments/{investmentId} {
      allow read: if signedIn() && (
        resource.data.investorId == request.auth.uid ||
        resource.data.entrepreneurId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isInvestor();
      allow update: if isAdmin();
    }

    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if signedIn();
      allow update: if isAdmin() || isOwner(userId);
    }

    match /products/{productId} {
      allow read: if signedIn();
      allow create: if isEntrepreneur() || isAdmin();
      allow update: if signedIn() && (isAdmin() || isOwner(resource.data.sellerId));
      allow delete: if isAdmin() || isOwner(resource.data.sellerId);
    }

    match /cart/{cartId} {
      allow read, write: if isOwner(cartId);
    }

    match /orders/{orderId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if signedIn();
      allow update: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if signedIn() && (isAdmin() || isOwner(resource.data.userId));
    }

    // --- CATCH ALL ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
