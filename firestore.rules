rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isEntrepreneur() {
      return signedIn() && (userRole() == 'Entrepreneur' || userRole() == 'entrepreneur');
    }

    function isInvestor() {
      return signedIn() && (userRole() == 'Investor' || userRole() == 'investor');
    }

    function isChatParticipant(chatId) {
      return signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    function isPitchOwnerFromId(pitchId) {
      return signedIn() && (
        get(/databases/$(database)/documents/pitches/$(pitchId)).data.userId == request.auth.uid
        || get(/databases/$(database)/documents/pitches/$(pitchId)).data.entrepreneurId == request.auth.uid
      );
    }

    match /users/{userId} {
      allow read, create, update: if isOwner(userId);
      allow delete: if false;
    }

    match /pitches/{pitchId} {
      allow read: if signedIn();

      allow create: if isEntrepreneur()
        && (
          request.resource.data.userId == request.auth.uid
          || request.resource.data.entrepreneurId == request.auth.uid
        );

      allow update: if (
        (resource.data.userId == request.auth.uid || resource.data.entrepreneurId == request.auth.uid)
        || (
          isInvestor()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status'])
          && resource.data.status == 'Open'
          && (request.resource.data.status == 'accepted' || request.resource.data.status == 'rejected')
        )
      );

      allow delete: if resource.data.userId == request.auth.uid || resource.data.entrepreneurId == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid || resource.data.recipientId == request.auth.uid
      );

      // App currently creates notifications from client writes.
      allow create: if signedIn()
        && request.resource.data.userId is string
        && request.resource.data.userId.size() > 0;

      allow update: if signedIn()
        && (resource.data.userId == request.auth.uid || resource.data.recipientId == request.auth.uid)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['read', 'isRead']);

      allow delete: if false;
    }

    match /transactions/{transactionId} {
      allow create: if signedIn()
        && request.resource.data.investorId == request.auth.uid
        && request.resource.data.pitchId is string
        && request.resource.data.amount is number;

      allow read: if signedIn() && (
        resource.data.investorId == request.auth.uid
        || resource.data.entrepreneurId == request.auth.uid
      );

      allow update, delete: if false;
    }

    match /pitchViews/{viewId} {
      allow create: if signedIn()
        && request.resource.data.investorId == request.auth.uid
        && request.resource.data.pitchId is string;

      allow read: if signedIn() && (
        resource.data.investorId == request.auth.uid
        || isPitchOwnerFromId(resource.data.pitchId)
      );

      allow update, delete: if false;
    }

    match /chats/{chatId} {
      allow create: if signedIn()
        && request.resource.data.participants is list
        && request.auth.uid in request.resource.data.participants;

      allow read, update: if signedIn()
        && request.auth.uid in resource.data.participants;

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isChatParticipant(chatId);

        allow create: if isChatParticipant(chatId)
          && request.resource.data.senderId == request.auth.uid;

        allow update, delete: if false;
      }
    }

    match /feedback/{feedbackId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
