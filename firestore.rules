rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- BASIC HELPERS ---
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userRole() {
      // Use getAfter if you're updating the role in the same transaction, 
      // but standard get is best for read-time RBAC.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isRole(role) {
      // Allow both 'Stakeholder' and 'stakeholder' (case-insensitive check)
      let r = userRole();
      return signedIn() && (r == role || r == role.lower());
    }

    function isStakeholder() {
      return isRole('Stakeholder');
    }

    function isEntrepreneur() {
      return isRole('Entrepreneur');
    }

    function isInvestor() {
      return isRole('Investor');
    }

    function isChatParticipant(chatId) {
      let chat = get(/databases/$(database)/documents/chats/$(chatId)).data;
      return signedIn() && (
        (chat.participants is list && request.auth.uid in chat.participants) ||
        chat.investorId == request.auth.uid ||
        chat.entrepreneurId == request.auth.uid
      );
    }

    function canAccessChat(data) {
      return signedIn() && (
        (data.participants is list && request.auth.uid in data.participants) ||
        data.investorId == request.auth.uid ||
        data.entrepreneurId == request.auth.uid
      );
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if isOwner(userId);
    }

    match /pitches/{pitchId} {
      allow read: if signedIn(); 
      allow create: if isEntrepreneur();
      allow update: if signedIn() && (
        isOwner(resource.data.userId) || isOwner(resource.data.entrepreneurId)
        || isInvestor() // Investors can express interest (updates raisedAmount/interested)
        || isStakeholder() // Stakeholders update vetting status
      );
    }

    match /milestones/{milestoneId} {
      // Global read for stakeholders to find vetting tasks
      allow read: if signedIn();
      allow create: if isEntrepreneur();
      allow update: if signedIn() && (
        (isEntrepreneur() && resource.data.entrepreneurId == request.auth.uid) ||
        isStakeholder()
      );
    }

    match /meetings/{meetingId} {
      // Diagnostic proved list/get works if auth. 
      // Restoring privacy: only participants can see the meeting.
      allow read: if signedIn() && (
        resource.data.stakeholderId == request.auth.uid || 
        resource.data.entrepreneurId == request.auth.uid
      );
      
      // Allow creation if the user is authenticated and claiming their own ID
      allow create: if signedIn() && request.resource.data.stakeholderId == request.auth.uid;
      
      allow update, delete: if signedIn() && request.auth.uid == resource.data.stakeholderId;
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || resource.data.recipientId == request.auth.uid);
      allow create: if signedIn();
      allow update: if signedIn() && (resource.data.userId == request.auth.uid || resource.data.recipientId == request.auth.uid);
    }

    match /pitchViews/{viewId} {
      allow create: if signedIn() && request.resource.data.investorId == request.auth.uid;
      allow read: if signedIn() && (
        resource.data.investorId == request.auth.uid ||
        resource.data.entrepreneurId == request.auth.uid
      );
    }

    match /chats/{chatId} {
      allow read: if canAccessChat(resource.data);
      allow create: if canAccessChat(request.resource.data);
      allow update: if canAccessChat(resource.data) && canAccessChat(request.resource.data);
      
      match /messages/{messageId} {
        allow read, create: if isChatParticipant(chatId);
      }
    }

    match /transactions/{transactionId} {
      allow read: if signedIn() && (
        resource.data.investorId == request.auth.uid ||
        resource.data.entrepreneurId == request.auth.uid ||
        resource.data.userId == request.auth.uid
      );
      allow create: if isInvestor();
    }

    // --- CATCH ALL ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
